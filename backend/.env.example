# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Finnhub (required — news sentiment)
FINNHUB_API_KEY=your-finnhub-api-key

# OpenRouter (optional — News Intelligence AI analysis)
# Get a key at https://openrouter.ai — model: google/gemma-3-12b-it
# If missing, the news intelligence step is skipped silently each hour
OPENROUTER_API_KEY=your-openrouter-api-key

# CORS (optional — set to your deployed frontend URL)
FRONTEND_URL=https://your-frontend-domain.com

# SMTP email alerts (optional — for CRITICAL ticker notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
